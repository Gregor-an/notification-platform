@page "/notifications"
@rendermode InteractiveServer
@using Domain.Enums
@using Web.Services
@using Web.Components.Shared
@inject NotificationApiClient Api
@inject NavigationManager Nav

<PageTitle>Notifications — Notification Platform</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">All Notifications</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/notifications/create">Send New</MudButton>
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" />
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudPaper Elevation="2">
        <MudTable Items="@_items" Hover="true" Dense="true" Breakpoint="Breakpoint.Md">
            <HeaderContent>
                <MudTh>Recipient</MudTh>
                <MudTh>Channel</MudTh>
                <MudTh>Priority</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Attempts</MudTh>
                <MudTh>Created</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Recipient">@context.Recipient</MudTd>
                <MudTd DataLabel="Channel"><ChannelChip Channel="@context.ChannelType" /></MudTd>
                <MudTd DataLabel="Priority"><PriorityChip Priority="@context.Priority" /></MudTd>
                <MudTd DataLabel="Status"><StatusChip Status="@context.Status" /></MudTd>
                <MudTd DataLabel="Attempts">@context.AttemptCount</MudTd>
                <MudTd DataLabel="Created">@context.CreatedUtc.ToLocalTime().ToString("MMM dd, HH:mm")</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                   Href="@($"/notifications/{context.Id}")" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4">No notifications found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>

    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-4">
        <MudText Typo="Typo.body2">Total: @_totalCount</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                       Disabled="@(_page <= 1)" OnClick="PrevPage" />
        <MudText Typo="Typo.body2">Page @_page of @_totalPages</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                       Disabled="@(_page >= _totalPages)" OnClick="NextPage" />
    </MudStack>
}

@code {
    private const int PageSize = 15;
    private bool _loading = true;
    private string? _error;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages;
    private List<Application.DTOs.NotificationSummaryDto> _items = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await Api.GetNotificationsAsync(_page, PageSize);
            if (result is not null)
            {
                _items      = result.Items;
                _totalCount = result.TotalCount;
                _totalPages = (int)Math.Ceiling((double)_totalCount / PageSize);
                if (_totalPages == 0) _totalPages = 1;
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load notifications: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PrevPage()
    {
        if (_page > 1) { _page--; await LoadAsync(); }
    }

    private async Task NextPage()
    {
        if (_page < _totalPages) { _page++; await LoadAsync(); }
    }
}
